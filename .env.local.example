# ─────────────────────────────────────────────────────────────
# Copy this file to ".env.local" and fill in your real values.
# Until you do, the app runs in DEMO MODE (browser storage only).
# ─────────────────────────────────────────────────────────────

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# --- Email alerts on each new lead (optional) ---
# Get a free key at https://resend.com  →  API Keys
RESEND_API_KEY=
# Who receives the "new lead" email, and the verified "from" address:
LEAD_NOTIFY_TO=you@example.com
LEAD_NOTIFY_FROM=leads@yourdomain.com
