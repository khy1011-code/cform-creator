# ─────────────────────────────────────────────────────────────
# Copy this file to ".env.local" and fill in your real values.
# Until you do, the app runs in DEMO MODE (browser storage only).
# ─────────────────────────────────────────────────────────────

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# --- GoHighLevel (GHL) — push each lead into your GHL CRM ---
# In GHL: Automation → Workflows → new workflow → trigger "Inbound Webhook"
# → copy the webhook URL and paste it here. GHL then stores the contact and
# sends the "new signup" email from inside the workflow.
GHL_WEBHOOK_URL=

# --- Email alerts via Resend (OPTIONAL) ---
# Only if you ALSO want an email straight from this app. If GHL already
# sends the signup email, you can leave these blank.
RESEND_API_KEY=
LEAD_NOTIFY_TO=you@example.com
LEAD_NOTIFY_FROM=leads@yourdomain.com
